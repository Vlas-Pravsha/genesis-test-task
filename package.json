{
  "name": "genesis-test-task",
  "version": "0.1.0",
  "private": true,
  "description": "Genesis test task",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "pnpm prisma:generate && pnpm prisma:migrate:deploy && tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:staged": "lint-staged",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "swagger": "swagger-ui-watcher swagger/swagger.yml"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@upstash/redis": "^1.37.0",
    "better-result": "^2.8.1",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "prisma": "^7.6.0",
    "swagger-ui-watcher": "^2.1.14",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ultracite": "^7.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,jsonc}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
